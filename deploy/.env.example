# =============================================================================
# UniSSH production stack — environment template.
#
#   cp deploy/.env.example .env          # at the REPO ROOT (next to compose.yml)
#   # edit values, then:  docker compose up -d --build
#
# The real .env is gitignored. NOTHING secret is baked into images — all
# secrets are injected here at runtime. Config keys for the server use figment's
# UNISSH__SECTION__KEY convention (DOUBLE underscore between section and key).
# =============================================================================

# -----------------------------------------------------------------------------
# Caddy / TLS
# -----------------------------------------------------------------------------
# Public domain (ACME) example:  unissh.example.com
# LAN / air-gapped example:      unissh.local   (then set UNISSH_TLS_DIRECTIVE)
UNISSH_DOMAIN=unissh.example.com

# Single TLS knob. One of:
#   ""                      -> automatic public ACME, no account email (default;
#                              needs real public DNS + reachable :80).
#   "tls you@example.com"   -> automatic public ACME with an account email
#                              (recommended for prod — enables expiry notices).
#   "tls internal"          -> Caddy internal CA / self-signed (LAN / air-gapped).
UNISSH_TLS_DIRECTIVE=tls admin@example.com

# -----------------------------------------------------------------------------
# First-run setup  (no token required)
# -----------------------------------------------------------------------------
# There is NO bootstrap token. On first boot the server prints a one-time
# SETUP CODE to its log; the first user CLAIMS the instance with it from the
# client or admin panel:
#   docker compose logs server 2>&1 | grep -i "setup code"
#
# OPTIONAL — pin a deterministic setup code for IaC/automation instead of the
# random one printed to the log (leave unset for the default random code):
# UNISSH__SETUP__CODE=

# OPTIONAL — ops break-glass. A server-trusted token for the infrastructure
# /v1/ops/* surface (overview / instance / seq-bump). It is NOT a keyset and
# grants NO decryption. Empty/unset → the ops surface is DISABLED (default).
# Generate with: openssl rand -hex 32
# UNISSH__OPS__TOKEN=

# OPTIONAL — SSO via OpenID Connect ([oidc]; disabled by default). See
# server/config.example.toml [oidc] for the full field set (issuer, client_id,
# audience, jwks_url, groups_claim, group_map, …). Enable with:
# UNISSH__OIDC__ENABLED=true
# UNISSH__OIDC__ISSUER=https://idp.example.com
# UNISSH__OIDC__CLIENT_ID=unissh

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DEFAULT = SQLite. The shipped default backend is SQLite on the unissh-data
# volume and needs NO database secrets — POSTGRES_PASSWORD is NOT required for
# the default path. `docker compose config` resolves with only UNISSH_DOMAIN set.
# Leave these unset for the shipped default. Migrations auto-apply on boot.
UNISSH__DB__BACKEND=sqlite
UNISSH__DB__URL=/app/data/unissh.db

# --- Postgres mode (compose profile: postgres) -------------------------------
# The `postgres` profile REQUIRES POSTGRES_PASSWORD to be set (there is no safe
# default — postgres:16 refuses to start with an empty password). The default
# SQLite path above needs none of these.
#
# Profiles cannot rewrite the default `server` env, so to actually switch to
# Postgres you MUST set POSTGRES_PASSWORD + the keys below AND start the profile:
#
#   docker compose --profile postgres up -d --build
#
# Postgres container credentials (POSTGRES_PASSWORD is MANDATORY for this profile):
POSTGRES_USER=unissh
POSTGRES_DB=unissh
POSTGRES_PASSWORD=change-me-postgres-password
#
# Then point the server (and migrate init container) at Postgres by uncommenting.
# The migrate init container composes its DSN from POSTGRES_USER/PASSWORD/DB
# automatically; set UNISSH__DB__URL here only to override that, and keep the
# password in sync with POSTGRES_PASSWORD above:
# UNISSH__DB__BACKEND=postgres
# UNISSH__DB__URL=postgres://unissh:change-me-postgres-password@postgres:5432/unissh

# -----------------------------------------------------------------------------
# Monitoring (compose profile: monitoring)
# -----------------------------------------------------------------------------
# Prometheus scrapes server:9090 over the internal network (not host-published
# by default). Start with:  docker compose --profile monitoring up -d
# No extra env required.

---
import Icon from './Icon.astro';

interface Props {
  /** Section number. Owned by index.astro, which owns the order. */
  n: string;
  buildHref: string;
  deployHref: string;
  githubHref: string;
  releasesHref: string;
}
const { buildHref, deployHref, githubHref, releasesHref, n } = Astro.props;
// No typechecker runs on this repo (@astrojs/check is not installed), so the
// Props interface is documentation, not enforcement — a missing or numeric `n`
// rendered an empty/unpadded eyebrow and still exited 0. A frontmatter throw
// is the one thing that actually fails `astro build`.
if (!/^\d\d$/.test(n)) throw new Error(`DownloadCTA: n must be a zero-padded number like "01", got ${JSON.stringify(n)}`);
---

<section class="download" id="download" aria-labelledby="download-head">
  <div class="wrap">
    <span class="eyebrow"><i>{n}</i> · run it</span>
    <h2 id="download-head">Your servers. Your keys. <span class="grad-text">Your box.</span></h2>
    <p>
      Download a build, or compile it yourself. The sync server ships in the same repo and
      comes up with one compose file. Everything is open source.
    </p>

    <div class="download__cta">
      <a class="btn btn-primary btn-lg" href={releasesHref} rel="noopener">
        <Icon name="download" size={18} stroke={1.8} /> Download
      </a>
      <a class="btn btn-ghost btn-lg" href={buildHref}>Build from source</a>
      <a class="btn btn-ghost btn-lg" href={deployHref}>
        <Icon name="server" size={18} stroke={1.8} /> Deploy the server
      </a>
    </div>

    <!-- Releases are real: client.yml bundles via tauri-action and attaches
         SHA256SUMS + a provenance attestation. Two things this must not
         overstate:
           - the build matrix is ubuntu/windows/macos only (client.yml:44-52).
             Mobile is deliberately out of scope — "there is no privacy-
             preserving unsigned distributable for those stores/runtimes"
             (client.yml:24-26). The client SUPPORTS five platforms; you can
             DOWNLOAD three. Listing five under a Download button was a lie.
           - builds are UNSIGNED (no APPLE_* identity, no Windows cert), so
             macOS warns on first open. Say it here, not via Gatekeeper. -->
    <p class="download__note">
      downloads: macOS · Windows · Linux<br />
      iOS and Android are supported by the client but not distributed here — build them<br />
      builds are unsigned — macOS Gatekeeper will ask before the first launch<br />
      every release carries SHA256SUMS + a build provenance attestation<br />
      <a href={githubHref} rel="noopener" style="color:var(--site-violet-lite)">MIT OR Apache-2.0</a>
    </p>
  </div>
</section>

---
/**
 * The zero-knowledge pillars.
 *
 * Fact-checked against the code. The previous copy claimed the server
 * verified signatures "for auth and registration" over "only TLS 1.3":
 *   - there is no registration route anywhere in server/src. The v2 model
 *     is claim (modules/instance.rs:17), invite + join (identity.rs:37-40),
 *     SSO (oidc.rs:32) and a pending-grant queue (pending.rs:22).
 *   - TLS is optional and OFF by default (config.rs:27-28, :203); the
 *     expected deployment terminates it at a reverse proxy (:30).
 * Both are corrected below. Do not put them back.
 */
const pillars = [
  {
    n: '01',
    title: 'An untrusted ciphertext store',
    body: 'The server performs no payload crypto by design — it verifies an Ed25519 signature to authenticate a device, then stores what you hand it. A database dump gives an attacker only ciphertext.',
  },
  {
    n: '02',
    title: 'Keys never leave your device',
    body: 'Your Secret Key is generated locally and your private keyset is never uploaded. The core hands the UI public keys and fingerprints — never plaintext private keys.',
  },
  {
    n: '03',
    title: 'Honest about metadata',
    body: 'Content, including item names, is always encrypted. The social graph, blob sizes and sync timings are visible to whoever runs the server — that is you — and they are documented, not hidden.',
  },
];
---

<section class="section" id="zero-knowledge" aria-labelledby="trust-lead">
  <div class="wrap">
    <div class="panel">
      <span class="eyebrow"><i>01</i> · zero-knowledge</span>
      <p class="trust__lead" id="trust-lead">
        A dump of the database gives you <span class="grad-text">ciphertext</span>.
      </p>
      <div class="trust__pillars">
        {
          pillars.map((p) => (
            <div class="pillar">
              <div class="pillar__n">{p.n}</div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

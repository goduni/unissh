---
import Icon from './Icon.astro';

interface Props {
  securityHref: string;
}
const { securityHref } = Astro.props;

/**
 * The crypto claims. Every one of these was verified against the code
 * (crates/crypto, crates/keychain, crates/sync, server/src/store).
 * If you add a row here, go read the line first.
 */
const claims = [
  {
    title: 'XChaCha20-Poly1305 AEAD',
    desc: 'with associated data binding vault_id, item_id and version.',
  },
  { title: 'Argon2id KDF', desc: 'derives the Unlock Key from your passphrase, combined with the Secret Key.' },
  { title: 'HPKE / X25519 wrapping', desc: 'RFC 9180 DHKEM wraps per-item and vault keys for sharing.' },
  { title: 'Ed25519 signed versions', desc: 'monotonic and anti-rollback, with tombstones.' },
  { title: 'In-memory SSH agent', desc: 'mlock + zeroize; private keys never hit disk.' },
  { title: 'ProxyJump over the agent', desc: 'chained bastions — the key is never handed to the bastion.' },
  { title: 'Append-only audit log', desc: 'server-side SHA-256 hash chain, tamper-evident.' },
  {
    title: 'Verify-before-apply sync',
    desc: 'signature first, then highest signed version wins; conflicts surface, never silently merge.',
  },
];
---

<section class="section" id="security" aria-labelledby="security-head">
  <div class="wrap">
    <div class="panel">
      <span class="eyebrow"><i>05</i> · security model</span>
      <div class="section-head" style="margin:0 0 4px;max-width:680px;text-align:left;">
        <h2 id="security-head">We don't roll our own crypto</h2>
      </div>

      <div class="security__claims">
        {
          claims.map((c) => (
            <div class="claim">
              <span class="claim__icon" aria-hidden="true">
                <Icon name="check" size={16} stroke={2.2} />
              </span>
              <div>
                <div class="claim__title">{c.title}</div>
                <div class="claim__desc">{c.desc}</div>
              </div>
            </div>
          ))
        }
      </div>

      <p class="security__foot">
        Built on RustCrypto, <code>hpke</code> and SQLCipher —
        <a href={securityHref}>read the zero-knowledge model &rarr;</a>
      </p>
    </div>
  </div>
</section>

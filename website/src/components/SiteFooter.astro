---
interface Props {
  links: {
    overview: string;
    quickstart: string;
    install: string;
    arch: string;
    security: string;
    crates: string;
    server: string;
    deploy: string;
    github: string;
    githubReleases: string;
  };
}
const { links } = Astro.props;

const columns = [
  {
    title: 'Product',
    items: [
      { label: 'Download', href: links.githubReleases },
      { label: 'Security model', href: links.security },
      { label: 'Sync server', href: links.server },
      { label: 'Install', href: links.install },
    ],
  },
  {
    title: 'Docs',
    items: [
      { label: 'What is unissh', href: links.overview },
      { label: 'Quickstart', href: links.quickstart },
      { label: 'Architecture', href: links.arch },
      { label: 'Crate reference', href: links.crates },
    ],
  },
  {
    title: 'Project',
    items: [
      { label: 'GitHub', href: links.github },
      { label: 'Deploy the server', href: links.deploy },
      { label: 'Server & API', href: links.server },
    ],
  },
];
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer__top">
      <div class="footer__brand">
        <a class="brand" href="#top" aria-label="unissh home">
          <span class="brand__glyph" aria-hidden="true">&gt;_</span>
          <span class="brand__name">unissh</span>
        </a>
        <p>A modern, fully open-source SSH client with a built-in sync server.</p>
      </div>

      {
        columns.map((col) => (
          <nav class="footer__col" aria-label={col.title}>
            <h3>{col.title}</h3>
            <ul>
              {col.items.map((it) => (
                <li>
                  <a href={it.href} rel={it.href.startsWith('http') ? 'noopener' : undefined}>
                    {it.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
  </div>
</footer>

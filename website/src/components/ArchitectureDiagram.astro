---
import Icon from './Icon.astro';

interface Props {
  /** Section number. Owned by index.astro, which owns the order. */
  n: string;
  archHref: string;
}
const { archHref, n } = Astro.props;
// No typechecker runs on this repo (@astrojs/check is not installed), so the
// Props interface is documentation, not enforcement — a missing or numeric `n`
// rendered an empty/unpadded eyebrow and still exited 0. A frontmatter throw
// is the one thing that actually fails `astro build`.
if (!/^\d\d$/.test(n)) throw new Error(`ArchitectureDiagram: n must be a zero-padded number like "01", got ${JSON.stringify(n)}`);

/** rust-core/crates/* — nine of them. Verified against the workspace. */
const crates = [
  'crypto',
  'keychain',
  'storage',
  'vault',
  'ssh-agent',
  'ssh-transport',
  'sync',
  'ffi',
  'cli',
];

const nodes = [
  { icon: 'terminal', name: 'client', role: 'Tauri 2 + React', dep: 'unissh-ffi path dep' },
  { icon: 'server', name: 'server', role: 'axum + sqlx', dep: 'format parity, not a dep' },
  { icon: 'globe', name: 'server-ui', role: 'React + crypto-wasm', dep: 'admin panel' },
];
---

<section class="section" id="sync-server" aria-labelledby="arch-head">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow"><i>{n}</i> · architecture</span>
      <h2 id="arch-head">One core, <span class="grad-text">one set of formats</span></h2>
      <p>
        A nine-crate Cargo workspace is the foundation. The client and the admin panel
        compile against it. The server deliberately does not — it keeps its own minimal
        implementation of the same formats, on the same libraries, held byte-compatible
        by a parity test, so that it needs no crypto it could misuse.
      </p>
    </div>

    <div class="arch-grid">
      {
        nodes.map((n) => (
          <div class="arch-node">
            <div class="arch-node__icon" aria-hidden="true">
              <Icon name={n.icon} size={19} stroke={1.8} />
            </div>
            <div class="arch-node__name">{n.name}</div>
            <div class="arch-node__role">{n.role}</div>
            <div class="arch-node__dep">{n.dep}</div>
          </div>
        ))
      }
    </div>

    <div class="crates-head">rust-core · 9 crates</div>
    <div class="crates">{crates.map((c) => <span class="crate">{c}</span>)}</div>

    <p class="arch__foot">
      <a href={archHref}>Read the system overview &rarr;</a>
    </p>
  </div>
</section>

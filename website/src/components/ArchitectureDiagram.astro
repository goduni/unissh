---
import Icon from './Icon.astro';

interface Props {
  archHref: string;
}
const { archHref } = Astro.props;

/** rust-core/crates/* — nine of them. Verified against the workspace. */
const crates = [
  'crypto',
  'keychain',
  'storage',
  'vault',
  'ssh-agent',
  'ssh-transport',
  'sync',
  'ffi',
  'cli',
];

const nodes = [
  { icon: 'terminal', name: 'client', role: 'Tauri 2 + React', dep: 'unissh-ffi path dep' },
  { icon: 'server', name: 'server', role: 'axum + sqlx', dep: 'SQLite or Postgres' },
  { icon: 'globe', name: 'server-ui', role: 'React + crypto-wasm', dep: 'admin panel' },
];
---

<section class="section" id="sync-server" aria-labelledby="arch-head">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow"><i>03</i> · architecture</span>
      <h2 id="arch-head">One core feeds <span class="grad-text">three consumers</span></h2>
      <p>
        A nine-crate Cargo workspace is the shared foundation. The client, the sync server
        and the admin panel all build on it — none of them reinvents the crypto.
      </p>
    </div>

    <div class="arch-grid">
      {
        nodes.map((n) => (
          <div class="arch-node">
            <div class="arch-node__icon" aria-hidden="true">
              <Icon name={n.icon} size={19} stroke={1.8} />
            </div>
            <div class="arch-node__name">{n.name}</div>
            <div class="arch-node__role">{n.role}</div>
            <div class="arch-node__dep">{n.dep}</div>
          </div>
        ))
      }
    </div>

    <div class="crates-head">rust-core · 9 crates</div>
    <div class="crates">{crates.map((c) => <span class="crate">{c}</span>)}</div>

    <p class="arch__foot">
      <a href={archHref}>Read the system overview &rarr;</a>
    </p>
  </div>
</section>

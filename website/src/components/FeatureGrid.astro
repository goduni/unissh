---
/**
 * What the client actually does.
 *
 * Fact-checked against the code. Corrections made here — do not revert:
 *   - "seven terminal themes" was wrong: TERM_THEMES (tokens.ts:361-371)
 *     ships NINE (nebula, dracula, nord, gruvbox, solarized, tokyo,
 *     solight, candy-light, candy-dark) — two of them light.
 *   - "Fleet & broadcast exec" were two features; the client merged them
 *     into ONE "Run" screen with two modes (Shell.tsx:24, :864;
 *     App.tsx:36-39 routes run/fleet/broadcast all to <ViewRun/>).
 *
 * Added, because they are real and the page never mentioned them:
 *   - escrow recovery (server/src/modules/escrow.rs:12-15,177-188)
 *   - device pairing over an untrusted relay (identity.rs:26-30)
 *   - vault-key rotation / key epochs (vault/src/lib.rs:16,32) — what
 *     makes "revocation" cryptographic rather than a server promise.
 */
const features = [
  {
    lbl: 'a · vaults',
    title: 'Encrypted, per item',
    body: 'Envelope encryption with per-item keys under a Vault Key. Passwords, notes, SSH keys and host profiles, with version history and strictly type-gated reveal.',
  },
  {
    lbl: 'b · run',
    title: 'One screen, two modes',
    body: 'Exec across a group with concurrency limits and per-host timeouts, or broadcast one input into many live PTYs. Dry-run first, then push files fleet-wide over SFTP.',
  },
  {
    lbl: 'c · terminal',
    title: 'Real PTYs, nine themes',
    body: 'Interactive sessions with resize, separate streaming stdout/stderr exec, and automatic reconnect with backoff.',
  },
  {
    lbl: 'd · transfer',
    title: 'SFTP & tunnels',
    body: 'Full SFTP with resumable transfers, progress and cancel. Local, remote and dynamic (SOCKS5) forwards, plus ProxyJump chains through your own bastions.',
  },
  {
    lbl: 'e · recovery',
    title: 'Lose the passphrase, keep the vault',
    body: 'Constant-time escrow, hardened with decoy parameters so the server cannot tell an enrolled account from an unenrolled one — and never sees a plaintext key.',
  },
  {
    lbl: 'f · revocation',
    title: 'Cryptographic, not promised',
    body: 'Rotating a vault key rewraps every member grant and raises the key epoch. Sync enforces the floor, so a removed member cannot read what comes next.',
  },
];
---

<section class="section" id="features" aria-labelledby="features-head">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow"><i>02</i> · the client</span>
      <h2 id="features-head">Everything you'd open a <span class="grad-text">terminal</span> for</h2>
      <p>
        One Rust core behind macOS, Windows, Linux, iOS and Android — so a host you add on
        the laptop is on the phone before you reach for it.
      </p>
    </div>

    <div class="feature-grid">
      {
        features.map((f) => (
          <article class="feature">
            <span class="feature__lbl">{f.lbl}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

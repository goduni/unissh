---
/**
 * The real client, drawn from client/src — not from imagination.
 *
 *  desktop (>=1180px) : the Terminal route — native macOS titlebar
 *    (tauri decorations:true, so the OS draws the lights), the 44px
 *    in-app toolbar (App.tsx:352-406), the 220px nav with its three
 *    groups (Shell.tsx:760-899), TermTabStrip (TermTabStrip.tsx:36-345)
 *    and the 30px status bar (ViewTerminal.tsx:1443-1530).
 *
 *  phone (<1180px) : the real mobile shell (mobile/MobileApp.tsx) —
 *    top bar with the vault pill + SyncBadge, the session switcher,
 *    the PTY, the 19-key accessory row (KEY_SEQ, :273-293) and the
 *    four-tab bar (:679-763). NOT the desktop window scaled down.
 *
 * Palette: the NEBULA family (tokens.ts DARK + ACCENTS.blue). Note the
 * app's *default* family is mono — see the note in theme.css.
 *
 * Deliberately absent, because the app has none of them: a right-hand
 * "Sync" panel (sync state is the SyncBadge in the vault card), a
 * latency/ping readout (ViewHosts.tsx:4-5), a port on host rows, and
 * any glow on status dots (StatusDot's `glow` defaults off).
 */
---

<!-- ============================================================
     THE REAL CLIENT — drawn from client/src, not from imagination.
     Palette: NEBULA dark (tokens.ts DARK + ACCENTS.blue).
     Desktop = Terminal route: native titlebar · 44px toolbar · 220px nav · tabstrip/xterm/statusbar.
     Mobile  = the real mobile shell: top bar · session switcher · xterm · 19-key bar · 4 tabs.
     ============================================================ -->

<!-- ============ DESKTOP (>=1180px) ============ -->
<div class="uapp uapp--desk">
  <!-- native macOS titlebar: tauri decorations:true, the OS draws these -->
  <div class="uapp__native"><span class="lights"><i style="background:#ff5f57"></i><i style="background:#febc2e"></i><i style="background:#28c840"></i></span></div>

  <!-- App.tsx:352-406 — 44px in-app toolbar -->
  <div class="uapp__bar">
    <span class="ulogo">
      <i class="ulogo__mark">›_</i><span class="ulogo__wm">Uni<em>SSH</em></span>
    </span>
    <span class="uapp__barmid">
      <span class="usearch">
        <svg class="i" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
        Search hosts, commands, secrets…
        <span class="usearch__kbd">⌘K</span>
      </span>
    </span>
    <span class="uapp__barright">
      <span class="utib"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg></span>
      <span class="utib"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6"/></svg></span>
      <span class="utib"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
      <span class="uav">g</span>
    </span>
  </div>

  <div class="uapp__body">
    <!-- Shell.tsx:760-899 — 220px sidebar -->
    <aside class="unav">
      <div class="unav__grp">Hosts <span class="unav__ga"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6"/></svg></span></div>
      <div class="uni"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="8" rx="2"/><rect x="2" y="13" width="20" height="8" rx="2"/><path d="M6 7h.01M6 17h.01"/></svg><span class="uni__l">All hosts</span><span class="uni__c">12</span></div>
      <div class="uni uni--sub"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span class="uni__l">edge</span><span class="uni__c">4</span></div>
      <div class="uni uni--sub"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5M3 12c0 1.7 4 3 9 3s9-1.3 9-3"/></svg><span class="uni__l">db</span><span class="uni__c">3</span></div>

      <div class="unav__grp">Operations</div>
      <div class="uni is-on"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 17l6-5-6-5M12 19h8"/></svg><span class="uni__l">Terminals</span><i class="uni__dot"></i><span class="uni__c">3</span></div>
      <div class="uni"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.7-.9L9.6 3.9A2 2 0 0 0 7.9 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2z"/></svg><span class="uni__l">SFTP</span></div>
      <div class="uni"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8a6 6 0 0 1 0 8.4M7.8 16.2a6 6 0 0 1 0-8.4M19.1 4.9a10 10 0 0 1 0 14.2M4.9 19.1a10 10 0 0 1 0-14.2"/></svg><span class="uni__l">Run</span></div>

      <div class="unav__grp">Vault &amp; network</div>
      <div class="uni"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="4.5"/><path d="M10.7 12.3L21 2M17 6l3 3M14 9l3 3"/></svg><span class="uni__l">Secrets</span><span class="uni__c">27</span></div>
      <div class="uni"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg><span class="uni__l">Tunnels</span></div>
      <div class="uni"><svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg><span class="uni__l">Known hosts</span><span class="uni__c">9</span></div>

      <div class="unav__sp"></div>
      <!-- Shell.tsx:429-506 — vault switcher; SyncBadge lives HERE, not in a right panel -->
      <div class="unav__foot">
        <div class="uvault">
          <span class="uavx">i</span>
          <span class="uvault__t">
            <span class="uvault__l1">infra<svg class="i" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#3ad29f;flex:none"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg></span>
            <span class="uvault__l2">
              <span class="ubadge"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.3A7 7 0 1 0 5 16h13a4 4 0 0 0 0-8z"/></svg>ops</span>
              <span class="usync"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>Synced</span>
            </span>
          </span>
          <svg class="uvault__cd" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </div>
      </div>
    </aside>

    <!-- ViewTerminal.tsx:1332-1533 -->
    <div class="uterm">
      <!-- TermTabStrip.tsx:36-345 -->
      <div class="utabs">
        <span class="utab is-on"><i class="udot"></i>prod-web-01<span class="utab__x">✕</span></span>
        <span class="utab"><i class="udot udot--ring"></i>staging-db<span class="utab__x">✕</span></span>
        <span class="utab"><i class="udot"></i>bastion<span class="utab__pc">2</span><span class="utab__x">✕</span></span>
        <span class="utab__plus">+</span>
      </div>

      <!-- the PTY body is the ONLY thing tinted by the terminal theme (nebula: #0c0e16) -->
      <div class="upty">
        <div><span class="c-g">ubuntu</span><span class="c-f">@</span><span class="c-p">prod-web-01</span><span class="c-f">:~$</span> neofetch</div>
        <div class="upty__row">
          <pre class="upty__art">            .-/+oossssoo+/-.
        `:+ssssssssssssssssss+:`
      -+ssssssssssssssssssyyssss+-
    .ossssssssssssssssssdMMMNysssso.
   /sssssssssshdmmNNmmyNMMMMhssssss/
  +sssssssshmydMMMMMMMNddddyssssssss+
 /sssssssshNMMMyhhyyyyhmNMMMNhssssss/
.ssssssssdMMMNhsssssssshNMMMdssssssss.
+sssshhhyNMMNyssssssssssyNMMMysssssss+
ossyNMMMNyMMhssssssssssssshmmmhssssso
ossyNMMMNyMMhsssssssssssssshmmmhssssso
+sssshhhyNMMNyssssssssssyNMMMysssssss+
.ssssssssdMMMNhsssssssshNMMMdssssssss.
 /sssssssshNMMMyhhyyyyhdNMMMNhssssss/
  +sssssssssdmydMMMMMMMMddddyssssssss+
   /sssssssssshdmNNNNmyNMMMMhssssss/
    .ossssssssssssssssssdMMMNysssso.
      -+sssssssssssssssssyyyssss+-
        `:+ssssssssssssssssss+:`
            .-/+oossssoo+/-.</pre>
          <div class="upty__info">
            <div><span class="c-g">ubuntu</span><span class="c-f">@</span><span class="c-p">prod-web-01</span></div>
            <div class="c-d">-----------------</div>
            <div><span class="c-b">OS</span><span class="c-f">: Ubuntu 22.04.4 LTS x86_64</span></div>
            <div><span class="c-b">Host</span><span class="c-f">: Ubuntu 22.04 LTS</span></div>
            <div><span class="c-b">Kernel</span><span class="c-f">: 5.15.0-101-generic</span></div>
            <div><span class="c-b">Uptime</span><span class="c-f">: 2 days, 4 hours, 12 mins</span></div>
            <div><span class="c-b">Packages</span><span class="c-f">: 1184 (dpkg)</span></div>
            <div><span class="c-b">Shell</span><span class="c-f">: bash 5.1.16</span></div>
            <div><span class="c-b">Terminal</span><span class="c-f">: unissh</span></div>
            <div><span class="c-b">CPU</span><span class="c-f">: Intel i7-10700K (16) @ 3.800GHz</span></div>
            <div><span class="c-b">Memory</span><span class="c-f">: 2456MiB / 15902MiB</span></div>
            <div class="upal"><i style="background:#333541"></i><i style="background:#ff6b8b"></i><i style="background:#3ad29f"></i><i style="background:#ffcf6b"></i><i style="background:#5b8cff"></i><i style="background:#b98cff"></i><i style="background:#57c7ff"></i><i style="background:#d8def2"></i></div>
            <div class="upal"><i style="background:#565d78"></i><i style="background:#ff8299"></i><i style="background:#5cd8ae"></i><i style="background:#ffd583"></i><i style="background:#75a0ff"></i><i style="background:#c49dff"></i><i style="background:#79d1ff"></i><i style="background:#ffffff"></i></div>
          </div>
        </div>
        <div class="upty__pr"><span class="c-g">ubuntu</span><span class="c-f">@</span><span class="c-p">prod-web-01</span><span class="c-f">:~$</span> <span class="caret"></span></div>
      </div>

      <!-- ViewTerminal.tsx:1443-1530 — 30px status bar, desktop only -->
      <div class="ustat">
        <span class="ustat__s"><i class="udot"></i>connected</span>
        <span class="ustat__h">ubuntu@10.0.0.12</span>
        <span class="ustat__b"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span>
        <span class="ustat__b"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg></span>
        <span class="ustat__sp"></span>
        <span class="ustat__th">theme: UniSSH Nebula <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6"/></svg></span>
      </div>
    </div>
  </div>
</div>

<!-- ============ MOBILE (<1180px) — the real mobile shell ============ -->
<div class="uapp uapp--phone">
  <!-- MobileApp.tsx:77-204 — top bar: vault pill + a single search button -->
  <div class="mtop">
    <span class="mvault">
      <span class="uavx">i</span>
      <span class="uvault__t">
        <span class="uvault__l1">infra</span>
        <span class="uvault__l2">
          <span class="ubadge"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.3A7 7 0 1 0 5 16h13a4 4 0 0 0 0-8z"/></svg>ops</span>
          <span class="usync"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>Synced</span>
        </span>
      </span>
      <svg class="uvault__cd" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
    </span>
    <span class="mtop__sp"></span>
    <span class="mtop__btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg></span>
  </div>

  <!-- MobileApp.tsx:375-435 — session switcher, only when >1 tab -->
  <div class="msw">
    <span class="msw__i is-on"><i class="udot"></i>prod-web-01<span class="msw__x">✕</span></span>
    <span class="msw__i"><i class="udot udot--ring"></i>staging-db<span class="msw__x">✕</span></span>
    <span class="msw__i"><i class="udot"></i>bastion<span class="msw__x">✕</span></span>
  </div>

  <div class="upty upty--m">
    <div><span class="c-g">ubuntu</span><span class="c-f">@</span><span class="c-p">prod-web-01</span><span class="c-f">:~$</span> uptime -p</div>
    <div class="c-f">up 2 days, 4 hours, 12 minutes</div>
    <div><span class="c-g">ubuntu</span><span class="c-f">@</span><span class="c-p">prod-web-01</span><span class="c-f">:~$</span> systemctl is-active nginx</div>
    <div class="c-gr">active</div>
    <div class="upty__pr"><span class="c-g">ubuntu</span><span class="c-f">@</span><span class="c-p">prod-web-01</span><span class="c-f">:~$</span> <span class="caret"></span></div>
  </div>

  <!-- MobileApp.tsx:273-293 — KEY_SEQ, the 19 real keys, in order -->
  <div class="mkeys">
    <span class="mkey">esc</span><span class="mkey">tab</span><span class="mkey">^C</span><span class="mkey">^D</span><span class="mkey">^Z</span><span class="mkey">^L</span><span class="mkey">^R</span><span class="mkey">^A</span><span class="mkey">^E</span><span class="mkey">^W</span><span class="mkey">^U</span><span class="mkey">|</span><span class="mkey">~</span><span class="mkey">/</span><span class="mkey">-</span><span class="mkey">←</span><span class="mkey">↓</span><span class="mkey">↑</span><span class="mkey">→</span>
  </div>

  <!-- MobileApp.tsx:679-763 — 4 tabs, active = ink label + 2px accent tick -->
  <div class="mtabs">
    <span class="mtab"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="8" rx="2"/><rect x="2" y="13" width="20" height="8" rx="2"/><path d="M6 7h.01M6 17h.01"/></svg>Hosts</span>
    <span class="mtab is-on"><i class="mtab__tick"></i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 17l6-5-6-5M12 19h8"/></svg>Terminal</span>
    <span class="mtab"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>Run</span>
    <span class="mtab"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>More</span>
  </div>
</div>

<style>
/* ============================================================
   REAL CLIENT — tokens.ts NEBULA dark (DARK base + ACCENTS.blue)
   ============================================================ */
.uapp{
  --a-bg0:#0c0e14; --a-bg1:#10131c; --a-bg2:#161a26; --a-bg3:#1b2030; --a-bg4:#232a3d;
  --a-line:rgba(255,255,255,0.07); --a-line2:rgba(255,255,255,0.13);
  --a-txt:#eef0f7; --a-txt2:#9aa1b8; --a-txt3:#8b93ac;
  --a-accent:#5b8cff; --a-accentText:#5b8cff; --a-green:#3ad29f; --a-amber:#ffb454;
  /* terminal theme "UniSSH Nebula" — tokens.ts:362 */
  --t-bg:#0c0e16; --t-fg:#d8def2; --t-dim:#565d78; --t-green:#3ad29f;
  --t-blue:#5b8cff; --t-purple:#b98cff; --t-red:#ff6b8b;
  border:1px solid var(--a-line); border-radius:13px; overflow:hidden;
  background:var(--a-bg0); color:var(--a-txt);
  box-shadow:0 50px 120px -40px rgba(0,0,0,.95);
  text-align:left;
}
.uapp--desk{ display:none; }
.uapp--phone{ display:flex; flex-direction:column; max-width:400px; margin-inline:auto; }
@media (min-width:1180px){
  .uapp--desk{ display:block; }
  .uapp--phone{ display:none; }
}
.uapp .i{ flex:none; }

/* native macOS titlebar (tauri decorations:true — the OS draws the lights) */
.uapp__native{ height:30px; display:flex; align-items:center; padding:0 12px; background:var(--a-bg1); }
.lights{ display:flex; gap:7px; }
.lights i{ width:11px; height:11px; border-radius:50%; display:block; }

/* App.tsx:352-406 — 44px in-app toolbar */
.uapp__bar{
  height:44px; display:flex; align-items:center; gap:14px; padding:0 16px;
  background:var(--a-bg1); border-top:1px solid var(--a-line); border-bottom:1px solid var(--a-line);
}
.ulogo{ display:inline-flex; align-items:center; gap:9px; margin-left:4px; flex:none; }
.ulogo__mark{
  width:18px; height:18px; border-radius:5px; background:var(--a-accent);
  display:grid; place-items:center; font-family:var(--uh-font-mono); font-size:9px; font-weight:700;
  color:#fff; font-style:normal; letter-spacing:-.05em;
}
.ulogo__wm{ font-size:13.3px; font-weight:700; letter-spacing:-0.3px; }
.ulogo__wm em{ font-style:normal; color:var(--a-accent); }
.uapp__barmid{ flex:1; display:flex; justify-content:center; min-width:0; }
.usearch{
  display:inline-flex; align-items:center; gap:8px; width:380px; max-width:40%;
  height:30px; padding:0 12px; border-radius:8px; background:var(--a-bg2);
  border:1px solid var(--a-line); color:var(--a-txt3); font-size:13px; white-space:nowrap; overflow:hidden;
}
.usearch__kbd{
  margin-left:auto; font-family:var(--uh-font-mono); font-size:11px; padding:1px 6px;
  border-radius:6px; background:var(--a-bg3); border:1px solid var(--a-line);
}
.uapp__barright{ display:flex; align-items:center; gap:8px; flex:none; }
.utib{ width:30px; height:30px; border-radius:8px; display:grid; place-items:center; color:var(--a-txt2); }
.uav{
  width:30px; height:30px; border-radius:50%; display:grid; place-items:center;
  background:var(--a-bg3); border:1px solid var(--a-line); color:var(--a-txt2);
  font-size:13px; font-weight:700;
}
.uapp__body{ display:grid; grid-template-columns:220px minmax(0,1fr); min-width:0; }

/* Shell.tsx:760-899 — sidebar */

---
import Icon from './Icon.astro';

interface Props {
  docsHref: string;
  archHref: string;
  securityHref: string;
  /** Where the header Download button goes. */
  ctaHref: string;
  githubHref: string;
}

const { docsHref, archHref, securityHref, ctaHref, githubHref } = Astro.props;
---

<header class="site-header" id="site-header">
  <div class="site-header__inner">
    <a class="brand" href="#top" aria-label="unissh home">
      <span class="brand__glyph" aria-hidden="true">&gt;_</span>
      <span class="brand__name">unissh</span>
    </a>

    <nav class="site-nav" id="site-nav" aria-label="Primary">
      <a href={docsHref}>Docs</a>
      <a href={archHref}>Architecture</a>
      <a href={securityHref}>Security</a>
      <a href={githubHref} rel="noopener">Open Source</a>
    </nav>

    <div class="site-header__actions">
      <!-- No star count. A hardcoded one goes stale; a build-time one is the
           same thing laundered through a fetch, because docs.yml only rebuilds
           on pushes to website/** — the digit would refresh when we touch the
           site, not when someone stars the repo. A client-side fetch would be
           live, but it phones GitHub on every page load of a privacy tool.
           The link is always accurate and needs no number. -->
      <a class="gh-link" href={githubHref} rel="noopener">
        <Icon name="github" size={17} />
        Star on GitHub
      </a>
      <a class="btn btn-primary" href={ctaHref}>Download</a>
      <button class="burger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav" id="burger">
        <Icon name="menu" size={17} stroke={2} />
      </button>
    </div>
  </div>
</header>

<script>
  // The phone nav is a disclosure, not a route: reveal the same links in place
  // rather than shipping an overlay nobody asked for. A disclosure has to be
  // dismissible three ways or it is a trap — tapping a link left the panel
  // sitting on top of the section it had just scrolled to.
  const burger = document.getElementById('burger');
  const nav = document.getElementById('site-nav');
  const setOpen = (open: boolean) => {
    burger?.setAttribute('aria-expanded', String(open));
    nav?.classList.toggle('is-open', open);
  };
  burger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = burger.getAttribute('aria-expanded') !== 'true';
    setOpen(open);
    // The panel renders below the burger but sits BEFORE it in the DOM, so
    // Tab from the burger jumped past all six links to the hero CTA and they
    // were only reachable by Shift+Tab. Moving focus into the panel is the
    // disclosure pattern and it makes forward order match visual order.
    if (open) nav?.querySelector('a')?.focus();
  });
  // following one of its own links
  nav?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setOpen(false);
  });
  // Escape, with focus handed back to the control that opened it
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && burger?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      burger.focus();
    }
  });
  // a tap anywhere else
  document.addEventListener('click', (e) => {
    if (burger?.getAttribute('aria-expanded') !== 'true') return;
    if (!nav?.contains(e.target as Node)) setOpen(false);
  });
</script>

<style>
  /* Disclosure state for the phone nav. The desktop rule in landing.css
     takes over from 1080px up, where the burger is gone anyway. */
  .site-nav.is-open {
    display: flex;
    flex-direction: column;
    gap: 2px;
    position: absolute;
    left: 16px;
    right: 16px;
    top: 78px;
    z-index: 30;
    padding: 8px;
    border: 1px solid var(--uh-line2);
    border-radius: 16px;
    background: rgba(14, 17, 29, 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: var(--uh-shadow-card);
  }
  .site-nav.is-open a {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 0 12px;
    border-radius: 10px;
    font-size: 15px;
    color: var(--site-ink2);
  }
  .site-nav.is-open a:hover {
    background: var(--uh-bg2);
    color: var(--site-ink);
  }
  @media (min-width: 1080px) {
    .site-nav.is-open {
      position: static;
      flex-direction: row;
      padding: 0;
      border: 0;
      background: none;
      box-shadow: none;
      backdrop-filter: none;
    }
    .site-nav.is-open a {
      min-height: 0;
      padding: 0;
    }
  }
</style>
